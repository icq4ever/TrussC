// Auto-generated from addons/tcxTls/data/cacert.pem at configure time.
// Do not edit by hand. To refresh, run scripts/update_ca_bundle.sh and reconfigure.
//
// Embedded as a byte array instead of a string literal — MSVC rejects string
// literals above 65535 bytes (error C2026) and this bundle is ~226KB.

namespace trussc {
namespace tls_internal {

extern const char* bundledCaPem();
extern const char* bundledCaBundleDate();

static const unsigned char kPemData[] = {
@CA_BUNDLE_HEX@
};

const char* bundledCaPem() {
    return reinterpret_cast<const char*>(kPemData);
}

const char* bundledCaBundleDate() {
    return "@CA_BUNDLE_DATE@";
}

} // namespace tls_internal
} // namespace trussc
